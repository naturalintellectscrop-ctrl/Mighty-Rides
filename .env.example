# ============================================================================
# MIGHTY RIDES — Environment variables
# Copy to .env (gitignored) and fill in real values.
# ============================================================================

# --- Database (PostgreSQL via Supabase pooler) -------------------------------
# The direct db.<ref>.supabase.co host is IPv6-only — always use the IPv4 pooler.
#
# DATABASE_URL = runtime connection.
#   • On Vercel/serverless: TRANSACTION pooler (port 6543) + ?pgbouncer=true&connection_limit=1
#     postgresql://postgres.<ref>:<pwd>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#   • Locally: the session pooler (5432) is fine.
# DIRECT_URL = direct/session connection used by `prisma migrate` / `db push`
#   (SESSION pooler, port 5432) — pgbouncer can't run migrations.
DATABASE_URL="postgresql://postgres.<ref>:<pwd>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.<ref>:<pwd>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# --- NextAuth ----------------------------------------------------------------
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# --- App URLs (used for redirects, emails, payment callbacks) -----------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Flutterwave (payments) --------------------------------------------------
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-xxxx"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-xxxx"
# The exact "Secret hash" string you set in the Flutterwave dashboard webhook config.
# Flutterwave sends this verbatim in the `verif-hash` header (it is NOT an HMAC).
FLUTTERWAVE_SECRET_HASH="your-webhook-secret-hash"

# --- Resend (transactional email) --------------------------------------------
RESEND_API_KEY="re_xxxx"
EMAIL_FROM="Mighty Rides <no-reply@your-domain.com>"

# --- Cloudinary (image / ID document storage) --------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="xxxx"
CLOUDINARY_API_SECRET="xxxx"

# --- Upstash Redis (rate limiting) -------------------------------------------
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxx"

# --- Cron jobs (pickup/return reminders) -------------------------------------
# Sent as `Authorization: Bearer <CRON_SECRET>` by the scheduler.
CRON_SECRET="your-cron-secret"

# --- Contact / WhatsApp ------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER="256700000000"

# --- Analytics & monitoring (optional) ---------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_SENTRY_DSN=""
LOG_LEVEL="info"
